<%= page_header "Generate Program" do %>
  <%= btn_secondary "Back", client_path(@client) %>
<% end %>

<% if @has_assessment %>
  <p class="text-sm text-slate-500 mb-6">
    Generate a 12-week program based on <strong><%= @client.full_name %></strong>'s
    PrimeEight assessment and training age (<%= @client.training_age %>).
    Limiting lifts will determine exercise prioritization.
  </p>
<% else %>
  <div class="mb-6 px-4 py-3 rounded-md border-l-3 border-amber-500 bg-amber-50 text-amber-800 text-sm">
    No PrimeEight assessment found. The program will use a <strong>balanced</strong> macrocycle template
    without limiting lift prioritization. For personalized exercise selection,
    <%= link_to "run an assessment first", new_client_prime_eight_assessment_path(@client), class: "underline font-medium" %>.
  </div>
<% end %>

<%= form_with url: client_programs_path(@client), method: :post, class: "max-w-lg space-y-5" do |f| %>
  <div>
    <label class="block text-sm font-medium text-slate-500 mb-1">Goal</label>
    <select name="goal" required class="w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
      <option value="">Select goal</option>
      <option value="balanced">Balanced</option>
      <option value="hypertrophy">Hypertrophy</option>
      <option value="absolute_strength">Absolute Strength</option>
      <option value="relative_strength">Relative Strength</option>
      <option value="power">Power</option>
    </select>
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-500 mb-1">Volume Tolerance</label>
    <select name="volume" required class="w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
      <option value="">Select volume</option>
      <option value="low">Low</option>
      <option value="medium" selected>Medium</option>
      <option value="high">High</option>
    </select>
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-500 mb-1">Frequency (days/week)</label>
    <select name="frequency" required class="w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
      <option value="2">2x / week</option>
      <option value="3">3x / week</option>
      <option value="4" selected>4x / week</option>
      <option value="5">5x / week</option>
    </select>
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-500 mb-1">Accumulation Microcycle Structure</label>
    <select name="acc_microcycle" required class="w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
      <option value="1" selected>Structure 1: OH Press / Squat 1 / Bench Press / Front Squat</option>
      <option value="2">Structure 2: Incline Press / Squat 2 / Dip / Deadlift</option>
    </select>
    <p class="text-xs text-slate-400 mt-1">UB1 / LB1 / UB2 / LB2 session types for accumulation weeks</p>
  </div>

  <div>
    <label class="block text-sm font-medium text-slate-500 mb-1">Intensification Microcycle Structure</label>
    <select name="int_microcycle" required class="w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
      <option value="1">Structure 1: OH Press / Squat 1 / Bench Press / Front Squat</option>
      <option value="2" selected>Structure 2: Incline Press / Squat 2 / Dip / Deadlift</option>
    </select>
    <p class="text-xs text-slate-400 mt-1">UB1 / LB1 / UB2 / LB2 session types for intensification weeks</p>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <input type="submit" value="Generate Program" class="px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors" data-turbo-submits-with="Generating...">
    <%= link_to "Cancel", client_path(@client), class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>
