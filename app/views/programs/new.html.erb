<%= page_header "Generate Program" do %>
  <%= btn_secondary "Back", client_path(@client) %>
<% end %>

<% if @has_assessment %>
  <p class="text-sm text-slate-500 mb-6">
    Generate a 12-week program based on <strong><%= @client.full_name %></strong>'s
    PrimeEight assessment and training age (<%= @client.training_age %>).
  </p>
<% else %>
  <div class="mb-6 px-4 py-3 rounded-md border-l-3 border-amber-500 bg-amber-50 text-amber-800 text-sm">
    No PrimeEight assessment found. The program will use a <strong>balanced</strong> macrocycle template.
    <%= link_to "Run an assessment first", new_client_prime_eight_assessment_path(@client), class: "underline font-medium" %>.
  </div>
<% end %>

<% sc = "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1" %>

<%# Pre-populate from query params (e.g., when regenerating) %>
<% preset_goal = params[:goal].to_s %>
<% preset_freq = (params[:frequency] || 4).to_i %>
<% preset_volume = (params[:volume] || "medium").to_s %>

<%# Build JSON data for ALL splits for this training level %>
<% all_splits = KiloTrainingSplit.where(training_level: @client.training_age).order(:goal, :phase, :frequency) %>
<% splits_json = all_splits.map { |s|
  struct = s.split_structure.is_a?(String) ? JSON.parse(s.split_structure) : s.split_structure
  { id: s.id, goal: s.goal, phase: s.phase, frequency: s.frequency,
    name: s.name, training_level: s.training_level,
    summary: s.session_type_summary, display: s.display_label_with_days }
}.to_json %>

<%= form_with url: client_programs_path(@client), method: :post, class: "max-w-2xl space-y-5" do |f| %>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Goal</label>
      <select name="goal" required class="<%= sc %>" id="goal-select" onchange="updateTrainingSplits()">
        <option value="">Select goal</option>
        <% [["balanced", "Balanced"], ["hypertrophy", "Hypertrophy"], ["absolute_strength", "Absolute Strength"], ["relative_strength", "Relative Strength"], ["power", "Power"]].each do |val, label| %>
          <option value="<%= val %>" <%= 'selected' if preset_goal == val %>><%= label %></option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Volume Tolerance</label>
      <select name="volume" required class="<%= sc %>">
        <% %w[low medium high].each do |v| %>
          <option value="<%= v %>" <%= 'selected' if preset_volume == v %>><%= v.capitalize %></option>
        <% end %>
      </select>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Training Frequency</label>
      <select name="frequency" required class="<%= sc %>" id="frequency-select" onchange="updateTrainingSplits()">
        <% (2..5).each do |f| %>
          <option value="<%= f %>" <%= 'selected' if preset_freq == f %>><%= f %>x / week</option>
        <% end %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Microcycle Length</label>
      <div id="microcycle-length-display" class="px-3 py-2.5 rounded-md border border-slate-200 bg-slate-50 text-sm text-slate-600 font-['JetBrains_Mono',monospace]">
        7 days (1 week)
      </div>
    </div>
  </div>

  <%# === Training Split Selection === %>
  <div class="bg-white rounded-lg border border-slate-200 p-4" id="training-split-section">
    <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-2">Training Split</h3>
    <p class="text-xs text-slate-400 mb-3">
      Default auto-selected for the chosen Goal + Frequency.
      Override with any available split if needed.
    </p>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-medium text-slate-400 mb-1 flex items-center gap-1">
          <span class="inline-block w-2 h-2 rounded-sm bg-teal-600"></span> Accumulation Split
        </label>
        <select name="acc_split_id" class="<%= sc %>" id="acc-split-select">
          <option value="">Select goal first...</option>
        </select>
        <p class="text-xs text-slate-400 mt-1 font-['JetBrains_Mono',monospace] truncate" id="acc-split-preview"></p>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-400 mb-1 flex items-center gap-1">
          <span class="inline-block w-2 h-2 rounded-sm bg-amber-600"></span> Intensification Split
        </label>
        <select name="int_split_id" class="<%= sc %>" id="int-split-select">
          <option value="">Select goal first...</option>
        </select>
        <p class="text-xs text-slate-400 mt-1 font-['JetBrains_Mono',monospace] truncate" id="int-split-preview"></p>
      </div>
    </div>
  </div>

  <%# Mesocycle lengths per phase %>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-2">Mesocycle Length (weeks per phase)</h3>
    <p class="text-xs text-slate-400 mb-3">Default is 3 weeks per mesocycle (12 weeks total). Adjust per phase if needed.</p>
    <div class="grid grid-cols-4 gap-3">
      <% [["Acc 1", "acc1_weeks", "teal"], ["Int 1", "int1_weeks", "amber"], ["Acc 2", "acc2_weeks", "teal"], ["Int 2", "int2_weeks", "amber"]].each do |label, name, color| %>
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1 flex items-center gap-1">
            <span class="inline-block w-2 h-2 rounded-sm bg-<%= color %>-600"></span> <%= label %>
          </label>
          <select name="<%= name %>" class="<%= sc %>">
            <% (1..6).each do |w| %>
              <option value="<%= w %>" <%= 'selected' if w == 3 %>><%= w %> <%= w == 1 ? 'week' : 'weeks' %></option>
            <% end %>
          </select>
        </div>
      <% end %>
    </div>
    <p class="text-xs text-slate-400 mt-2 font-['JetBrains_Mono',monospace]" id="total-weeks-display">Total: 12 weeks</p>
  </div>

  <% all_opts = Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS + Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS %>
  <% ub_opts = Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS %>
  <% lb_opts = Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS %>
  <% fb_opts = Kilo::MicrocycleStructures::FULL_BODY_OPTIONS %>

  <%# === Microcycle Structure Customization === %>
  <%# 2x Full Body %>
  <div data-split-type="full_body" data-freq="2" class="hidden space-y-4">
    <% { "Accumulation" => ["teal", { "full_body_1" => "squat_1_overhead_press", "full_body_2" => "front_squat_incline_press" }],
         "Intensification" => ["amber", { "full_body_1" => "squat_2_bench_press", "full_body_2" => "deadlift_dip" }]
       }.each do |phase, (color, defaults)| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4">
        <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-<%= color %>-600"></span> <%= phase %>
        </h3>
        <div class="grid grid-cols-2 gap-3">
          <% defaults.each do |slot, dv| %>
            <div>
              <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
              <select name="<%= phase == 'Accumulation' ? 'acc' : 'int' %>_structure[<%= slot %>]" class="<%= sc %>">
                <% fb_opts.each do |opt| %>
                  <option value="<%= opt %>" <%= 'selected' if opt == dv %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
                <% end %>
              </select>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 3x Full Body %>
  <div data-split-type="full_body" data-freq="3" class="hidden space-y-4">
    <% { "Accumulation" => ["teal", { "session_1" => "squat_1_overhead_press", "session_2" => "front_squat_incline_press", "session_3" => "squat_1_overhead_press" }],
         "Intensification" => ["amber", { "session_1" => "squat_2_bench_press", "session_2" => "deadlift_dip", "session_3" => "squat_2_bench_press" }]
       }.each do |phase, (color, defaults)| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4">
        <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-<%= color %>-600"></span> <%= phase %> (3x Full Body)
        </h3>
        <div class="grid grid-cols-3 gap-3">
          <% defaults.each_with_index do |(slot, dv), i| %>
            <div>
              <label class="block text-xs font-medium text-slate-400 mb-1"><%= %w[Monday Wednesday Friday][i] %></label>
              <select name="<%= phase == 'Accumulation' ? 'acc' : 'int' %>_structure[<%= slot %>]" class="<%= sc %>">
                <% fb_opts.each do |opt| %>
                  <option value="<%= opt %>" <%= 'selected' if opt == dv %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
                <% end %>
              </select>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 3x Upper/Lower %>
  <div data-split-type="upper_lower" data-freq="3" class="hidden space-y-4">
    <% { "Accumulation" => ["teal", { "session_1" => "overhead_press", "session_2" => "squat_1", "session_3" => "overhead_press" }],
         "Intensification" => ["amber", { "session_1" => "incline_press", "session_2" => "front_squat", "session_3" => "incline_press" }]
       }.each do |phase, (color, defaults)| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4">
        <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-<%= color %>-600"></span> <%= phase %> (3x Upper/Lower)
        </h3>
        <div class="grid grid-cols-3 gap-3">
          <% defaults.each_with_index do |(slot, dv), i| %>
            <div>
              <label class="block text-xs font-medium text-slate-400 mb-1"><%= %w[Monday Wednesday Friday][i] %></label>
              <select name="<%= phase == 'Accumulation' ? 'acc' : 'int' %>_structure[<%= slot %>]" class="<%= sc %>">
                <% all_opts.each do |opt| %>
                  <option value="<%= opt %>" <%= 'selected' if opt == dv %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
                <% end %>
              </select>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 4x Upper/Lower (7-day) %>
  <div data-split-type="upper_lower" data-freq="4" class="space-y-4">
    <% { "Accumulation" => ["teal", { "upper_body_1" => "overhead_press", "lower_body_1" => "squat_1", "upper_body_2" => "bench_press", "lower_body_2" => "front_squat" }],
         "Intensification" => ["amber", { "upper_body_1" => "incline_press", "lower_body_1" => "squat_2", "upper_body_2" => "dip", "lower_body_2" => "deadlift" }]
       }.each do |phase, (color, defaults)| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4">
        <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-<%= color %>-600"></span> <%= phase %>
        </h3>
        <div class="grid grid-cols-2 gap-3">
          <% defaults.each do |slot, dv| %>
            <% opts = slot.include?("upper") ? ub_opts : lb_opts %>
            <div>
              <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
              <select name="<%= phase == 'Accumulation' ? 'acc' : 'int' %>_structure[<%= slot %>]" class="<%= sc %>">
                <% opts.each do |opt| %>
                  <option value="<%= opt %>" <%= 'selected' if opt == dv %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
                <% end %>
              </select>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 5x Upper/Lower %>
  <div data-split-type="upper_lower" data-freq="5" class="hidden space-y-4">
    <% { "Accumulation" => ["teal", { "upper_body_1" => "overhead_press", "lower_body_1" => "squat_1", "upper_body_2" => "bench_press", "lower_body_2" => "front_squat", "upper_body_3" => "dip" }],
         "Intensification" => ["amber", { "upper_body_1" => "incline_press", "lower_body_1" => "squat_2", "upper_body_2" => "dip", "lower_body_2" => "deadlift", "upper_body_3" => "bench_press" }]
       }.each do |phase, (color, defaults)| %>
      <div class="bg-white rounded-lg border border-slate-200 p-4">
        <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm bg-<%= color %>-600"></span> <%= phase %>
        </h3>
        <div class="grid grid-cols-3 gap-3">
          <% defaults.each do |slot, dv| %>
            <% opts = slot.include?("upper") ? ub_opts : lb_opts %>
            <div>
              <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
              <select name="<%= phase == 'Accumulation' ? 'acc' : 'int' %>_structure[<%= slot %>]" class="<%= sc %>">
                <% opts.each do |opt| %>
                  <option value="<%= opt %>" <%= 'selected' if opt == dv %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
                <% end %>
              </select>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Body Part splits — exercises are auto-mapped from the split's session types %>
  <div data-split-type="body_part" class="hidden space-y-4">
    <div class="px-4 py-3 rounded-md border-l-3 border-blue-500 bg-blue-50 text-blue-800 text-sm">
      Body part split selected. Sessions are mapped to the closest KILO templates automatically.
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <input type="submit" value="Generate Program" class="px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors" data-turbo-submits-with="Generating...">
    <%= link_to "Cancel", client_path(@client), class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>

<script>
const ALL_SPLITS = <%= raw splits_json %>;

function updateTrainingSplits() {
  const goal = document.getElementById('goal-select').value;
  const freq = parseInt(document.getElementById('frequency-select').value);

  updateSplitDropdown('acc-split-select', 'acc-split-preview', goal, 'accumulation', freq);
  updateSplitDropdown('int-split-select', 'int-split-preview', goal, 'intensification', freq);
  updateStructureSections();
}

function updateSplitDropdown(selectId, previewId, goal, phase, freq) {
  const select = document.getElementById(selectId);
  const preview = document.getElementById(previewId);

  // Get ALL splits for this phase + frequency (not restricted by goal)
  let allForFreq = ALL_SPLITS.filter(s => s.phase === phase && s.frequency === freq);

  // Deduplicate by name (same split name at same freq = same structure)
  const seen = new Map();
  allForFreq.forEach(s => {
    const key = s.name + '|' + s.frequency;
    if (!seen.has(key)) seen.set(key, s);
  });
  const uniqueSplits = Array.from(seen.values());

  // Find the default for this goal (exact goal + phase + freq match)
  let defaultSplit = ALL_SPLITS.find(s => s.goal === goal && s.phase === phase && s.frequency === freq);

  // If no exact match, try closest lower frequency for the default
  if (!defaultSplit) {
    for (let f = freq - 1; f >= 2; f--) {
      defaultSplit = ALL_SPLITS.find(s => s.goal === goal && s.phase === phase && s.frequency === f);
      if (defaultSplit) break;
    }
  }

  select.innerHTML = '';

  if (uniqueSplits.length === 0 && !defaultSplit) {
    select.innerHTML = '<option value="">No splits available</option>';
    preview.textContent = '';
    return;
  }

  // Add "Default" option first
  const defaultOpt = document.createElement('option');
  defaultOpt.value = '';
  defaultOpt.textContent = defaultSplit
    ? `Default: ${defaultSplit.name} — ${defaultSplit.frequency}x/wk`
    : 'Default (auto)';
  defaultOpt.dataset.summary = defaultSplit ? defaultSplit.summary : '';
  defaultOpt.selected = true;
  select.appendChild(defaultOpt);

  // Add all available splits as override options
  uniqueSplits.forEach(split => {
    const opt = document.createElement('option');
    opt.value = split.id;
    opt.textContent = split.display;
    opt.dataset.summary = split.summary;
    select.appendChild(opt);
  });

  updateSplitPreview(selectId, previewId);
  select.onchange = function() {
    updateSplitPreview(selectId, previewId);
    updateStructureSections();
  };
}

function updateSplitPreview(selectId, previewId) {
  const select = document.getElementById(selectId);
  const preview = document.getElementById(previewId);
  const selected = select.options[select.selectedIndex];
  preview.textContent = selected ? (selected.dataset.summary || '') : '';
}

function updateStructureSections() {
  const freq = parseInt(document.getElementById('frequency-select').value);

  // Determine split type from the accumulation split selection
  const accSelect = document.getElementById('acc-split-select');
  const selectedOpt = accSelect.options[accSelect.selectedIndex];
  const splitLabel = selectedOpt ? selectedOpt.textContent : '';

  let splitType = 'upper_lower'; // default
  if (splitLabel.includes('Full Body')) splitType = 'full_body';
  else if (splitLabel.includes('Body Part')) splitType = 'body_part';

  // Show/hide structure sections
  document.querySelectorAll('[data-split-type]').forEach(el => {
    const typeMatch = el.dataset.splitType === splitType;
    const freqAttr = el.dataset.freq;
    const freqMatch = !freqAttr || parseInt(freqAttr) === freq;
    el.classList.toggle('hidden', !(typeMatch && freqMatch));
  });

  // Disable hidden selects so they don't submit
  document.querySelectorAll('[data-split-type] select').forEach(el => {
    el.disabled = el.closest('[data-split-type]').classList.contains('hidden');
  });
}

function updateTotalWeeks() {
  const weeks = ['acc1_weeks','int1_weeks','acc2_weeks','int2_weeks']
    .map(n => parseInt(document.querySelector(`[name="${n}"]`)?.value || 3))
    .reduce((a, b) => a + b, 0);
  const el = document.getElementById('total-weeks-display');
  if (el) el.textContent = `Total: ${weeks} weeks`;
}

// Initialize
document.addEventListener('DOMContentLoaded', function() {
  updateTrainingSplits();
  updateTotalWeeks();
  document.querySelectorAll('[name$="_weeks"]').forEach(el =>
    el.addEventListener('change', updateTotalWeeks));
});
</script>
