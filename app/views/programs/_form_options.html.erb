<%= turbo_frame_tag "program_options" do %>
  <% select_class = "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1" %>
  <% acc_defaults = Kilo::MicrocycleStructures.defaults_for(:accumulation, frequency) %>
  <% int_defaults = Kilo::MicrocycleStructures.defaults_for(:intensification, frequency) %>

  <% if frequency == 2 %>
    <%# 2x/week: Full Body microcycle structures %>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-sm bg-teal-600"></span>
        Accumulation Microcycle (Full Body)
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <% acc_defaults.each do |slot, default_val| %>
          <div>
            <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
            <select name="acc_structure[<%= slot %>]" class="<%= select_class %>">
              <% Kilo::MicrocycleStructures::FULL_BODY_OPTIONS.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if opt == default_val %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-sm bg-amber-600"></span>
        Intensification Microcycle (Full Body)
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <% int_defaults.each do |slot, default_val| %>
          <div>
            <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
            <select name="int_structure[<%= slot %>]" class="<%= select_class %>">
              <% Kilo::MicrocycleStructures::FULL_BODY_OPTIONS.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if opt == default_val %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>

  <% elsif frequency == 3 %>
    <%# 3x/week: 3 sessions per week, each independently selectable %>
    <% ub_and_lb = Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS + Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS %>

    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-sm bg-teal-600"></span>
        Accumulation Microcycle (3x/week)
      </h3>
      <p class="text-xs text-slate-400 mb-3">Mon / Wed / Fri — select session type for each day.</p>
      <div class="grid grid-cols-3 gap-3">
        <% %w[session_1 session_2 session_3].each_with_index do |slot, i| %>
          <div>
            <label class="block text-xs font-medium text-slate-400 mb-1"><%= %w[Monday Wednesday Friday][i] %></label>
            <select name="acc_structure[<%= slot %>]" class="<%= select_class %>">
              <% ub_and_lb.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if opt == acc_defaults[slot] %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-sm bg-amber-600"></span>
        Intensification Microcycle (3x/week)
      </h3>
      <div class="grid grid-cols-3 gap-3">
        <% %w[session_1 session_2 session_3].each_with_index do |slot, i| %>
          <div>
            <label class="block text-xs font-medium text-slate-400 mb-1"><%= %w[Monday Wednesday Friday][i] %></label>
            <select name="int_structure[<%= slot %>]" class="<%= select_class %>">
              <% ub_and_lb.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if opt == int_defaults[slot] %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>

  <% else %>
    <%# 4x+ Upper/Lower: per-slot selection %>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-sm bg-teal-600"></span>
        Accumulation Microcycle
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <% { "upper_body_1" => Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS,
             "lower_body_1" => Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS,
             "upper_body_2" => Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS,
             "lower_body_2" => Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS }.each do |slot, options| %>
          <div>
            <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
            <select name="acc_structure[<%= slot %>]" class="<%= select_class %>">
              <% options.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if opt == acc_defaults[slot] %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3 flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-sm bg-amber-600"></span>
        Intensification Microcycle
      </h3>
      <div class="grid grid-cols-2 gap-3">
        <% { "upper_body_1" => Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS,
             "lower_body_1" => Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS,
             "upper_body_2" => Kilo::MicrocycleStructures::UPPER_BODY_OPTIONS,
             "lower_body_2" => Kilo::MicrocycleStructures::LOWER_BODY_OPTIONS }.each do |slot, options| %>
          <div>
            <label class="block text-xs font-medium text-slate-400 mb-1"><%= slot.titleize %></label>
            <select name="int_structure[<%= slot %>]" class="<%= select_class %>">
              <% options.each do |opt| %>
                <option value="<%= opt %>" <%= 'selected' if opt == int_defaults[slot] %>><%= Kilo::MicrocycleStructures.label_for(opt) %></option>
              <% end %>
            </select>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Training Split Selection (filtered by training level and frequency) %>
  <% acc_splits = KiloTrainingSplit.where(phase: :accumulation, training_level: training_level)
       .where("frequency <= ?", frequency).order(:goal) %>
  <% int_splits = KiloTrainingSplit.where(phase: :intensification, training_level: training_level)
       .where("frequency <= ?", frequency).order(:goal) %>

  <% if acc_splits.any? || int_splits.any? %>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3">Training Split</h3>
      <p class="text-xs text-slate-400 mb-3">Optional. Select a specific training split or use the default from the microcycle structure above.</p>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1">Accumulation Split</label>
          <select name="acc_split_id" class="<%= select_class %>">
            <option value="">Default (from microcycle)</option>
            <% acc_splits.each do |split| %>
              <% struct = split.split_structure.is_a?(String) ? JSON.parse(split.split_structure) : split.split_structure %>
              <option value="<%= split.id %>">
                <%= split.goal.titleize %> · <%= split.frequency %>x/wk
                (<%= struct.values.uniq.map(&:titleize).join(", ") %>)
              </option>
            <% end %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1">Intensification Split</label>
          <select name="int_split_id" class="<%= select_class %>">
            <option value="">Default (from microcycle)</option>
            <% int_splits.each do |split| %>
              <% struct = split.split_structure.is_a?(String) ? JSON.parse(split.split_structure) : split.split_structure %>
              <option value="<%= split.id %>">
                <%= split.goal.titleize %> · <%= split.frequency %>x/wk
                (<%= struct.values.uniq.map(&:titleize).join(", ") %>)
              </option>
            <% end %>
          </select>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
