<%= page_header @client.full_name do %>
  <div class="flex items-center gap-3">
    <% if @program.active? %>
      <%= btn_primary "Regenerate", new_client_program_path(@client, @regenerate_params) %>
    <% end %>
    <%= btn_secondary "Back to Client", client_path(@client) %>
  </div>
<% end %>

<% if @program.archived? %>
  <div class="mb-4 px-4 py-3 rounded-md border border-amber-200 bg-amber-50 text-sm text-amber-800 font-['JetBrains_Mono',monospace]">
    Archived on <%= @program.archived_at&.strftime("%B %-d, %Y") %>
  </div>
<% end %>

<div class="font-['JetBrains_Mono',monospace] text-sm text-slate-500 mb-6">
  <%= @program.goal.titleize %> · <%= @program.training_level.capitalize %> · <%= @program.volume.capitalize %> Volume · Model <%= @program.periodization_model %> · Macrocycle <%= @program.macrocycle_number || 1 %> · <%= @program.split_type&.titleize || "Upper / Lower" %> · <%= @program.frequency %>x/week · A-Series: <%= @program.a_series_loading_method_resolved.capitalize %> Loading<% if @program.map_applied? %> · <span class="text-teal-600">MAP Applied</span><% end %>
</div>

<% program_prescribed = @program.prescribed_tonnage %>
<% program_actual = @program.actual_tonnage %>
<% if program_prescribed > 0 || program_actual > 0 %>
  <div class="mb-6 px-4 py-3 rounded-md border border-slate-200 bg-white">
    <div class="flex items-center gap-4">
      <% if program_prescribed > 0 %>
        <div>
          <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Total Tonnage</span>
          <p class="font-['JetBrains_Mono',monospace] text-lg font-semibold text-slate-800"><%= format_tonnage(program_prescribed) %></p>
          <span class="text-[10px] text-slate-400">Prescribed</span>
        </div>
      <% end %>
      <% if program_actual > 0 %>
        <div class="<%= 'border-l border-slate-200 pl-4' if program_prescribed > 0 %>">
          <span class="text-xs font-medium text-slate-400 uppercase tracking-wider"><%= program_prescribed > 0 ? 'Actual' : 'Total Tonnage' %></span>
          <p class="font-['JetBrains_Mono',monospace] text-lg font-semibold text-emerald-700"><%= format_tonnage(program_actual) %></p>
          <span class="text-[10px] text-slate-400">Logged</span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @program.optimizing_strength_ratios? %>
  <div class="mb-6 px-4 py-3 rounded-md border border-indigo-200 bg-indigo-50 text-sm">
    <div class="flex items-center gap-2.5 mb-1">
      <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-black bg-slate-800 text-white tracking-widest">OSR</span>
      <span class="font-bold text-base text-slate-800">Optimizing Strength Ratios</span>
    </div>
    <div class="grid grid-cols-2 gap-4 mt-2 text-indigo-700">
      <div>
        <span class="text-xs text-indigo-400">Upper Body Limiting Lift</span>
        <p class="font-medium"><%= @program.limiting_lift_upper&.to_s&.delete_prefix("upper_")&.titleize || "—" %></p>
      </div>
      <div>
        <span class="text-xs text-indigo-400">Lower Body Limiting Lift</span>
        <p class="font-medium"><%= @program.limiting_lift_lower&.to_s&.delete_prefix("lower_")&.titleize || "—" %></p>
      </div>
    </div>
  </div>
<% end %>

<%# Macrocycle Timeline %>
<% mesocycles = @macrocycles.first&.mesocycles&.order(:number)&.to_a || [] %>
<div class="mb-8">
  <h2 class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-2">Macrocycle Timeline</h2>
  <% total_weeks = mesocycles.sum { |m| m.microcycles.count } %>
  <div class="grid gap-0.5" style="grid-template-columns: repeat(<%= total_weeks %>, 1fr)">
    <% mesocycles.each do |mesocycle| %>
      <% mesocycle.microcycles.order(:week_number).each do |micro| %>
        <div class="px-1 py-2 text-center rounded-sm text-white text-xs font-['JetBrains_Mono',monospace] font-medium
          <%= mesocycle.accumulation? ? 'bg-teal-600' : 'bg-amber-600' %>">
          W<%= micro.week_number %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Block + Phase labels %>
  <% macro_num = @program.macrocycle_number || 1 %>
  <% phase_offsets = [0, 0, 1, 1] %>
  <div class="flex mt-1">
    <% block_num = 0 %>
    <% mesocycles.each_with_index do |mesocycle, i| %>
      <% phase_num = (macro_num - 1) * 2 + 1 + phase_offsets[i] %>
      <% meso_weeks = mesocycle.microcycles.count %>
      <div class="text-center font-['JetBrains_Mono',monospace] text-[10px] text-slate-400" style="flex: <%= meso_weeks %>">
        <%= mesocycle.phase.titleize %> <%= phase_num %>
      </div>
    <% end %>
  </div>

  <% unless @program.optimizing_strength_ratios? %>
    <%# Rep scheme per mesocycle %>
    <% seed_phases = Kilo::MacrocycleBuilder::PHASE_SEQUENCE %>
    <div class="flex mt-0.5">
      <% mesocycles.each_with_index do |mesocycle, i| %>
        <% meso_weeks = mesocycle.microcycles.count %>
        <% rep_record = KiloPeriodizationModel.find_by(
             model_id: @program.periodization_model,
             macrocycle_number: @program.macrocycle_number || 1,
             phase: seed_phases[i]&.dig(:seed_phase)
           ) %>
        <div class="text-center font-['JetBrains_Mono',monospace] text-[10px] font-medium <%= mesocycle.accumulation? ? 'text-teal-600' : 'text-amber-600' %>" style="flex: <%= meso_weeks %>">
          <%= rep_record&.rep_scheme || "—" %>
        </div>
      <% end %>
    </div>
  <% end %>
  <div class="flex mt-1 gap-2">
    <% mesocycles.each_slice(2) do |pair| %>
      <% block_num = (block_num || 0) + 1 %>
      <% pair_weeks = pair.sum { |m| m.microcycles.count } %>
      <div class="text-center text-[10px] font-semibold text-slate-600 border border-slate-300 rounded px-2 py-1 bg-slate-50" style="flex: <%= pair_weeks %>">
        Block <%= block_num %>
      </div>
    <% end %>
  </div>
</div>

<%# Session Accordion grouped by Block %>
<% block_number = 0 %>
<% meso_index = 0 %>
<% mesocycles.each_slice(2) do |block_pair| %>
  <% block_number += 1 %>
  <div class="mb-8">
    <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg text-slate-800 mb-4 pb-2 border-b border-slate-200">
      Block <%= block_number %>
    </h2>

    <% block_pair.each do |mesocycle| %>
      <% phase_num = (macro_num - 1) * 2 + 1 + phase_offsets[meso_index] %>
      <% meso_index += 1 %>
      <div class="mb-6">
        <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-base mb-2 flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-sm <%= mesocycle.accumulation? ? 'bg-teal-600' : 'bg-amber-600' %>"></span>
          <%= mesocycle.phase.titleize %> <%= phase_num %>
          <% unless @program.optimizing_strength_ratios? %>
            <% meso_rep_record = KiloPeriodizationModel.find_by(
                 model_id: @program.periodization_model,
                 macrocycle_number: @program.macrocycle_number || 1,
                 phase: seed_phases[meso_index - 1]&.dig(:seed_phase)
               ) %>
            <% if meso_rep_record&.rep_scheme.present? %>
              <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= mesocycle.accumulation? ? 'bg-teal-50 text-teal-700' : 'bg-amber-50 text-amber-700' %>"><%= meso_rep_record.rep_scheme %></span>
            <% end %>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-slate-100 text-slate-500"><%= mesocycle.effective_loading_strategy.titleize %> Loading</span>
          <% end %>
          <% meso_prescribed = mesocycle.prescribed_tonnage %>
          <% meso_actual = mesocycle.actual_tonnage %>
          <% if meso_prescribed > 0 %>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-slate-50 text-slate-500 font-['JetBrains_Mono',monospace]"><%= format_tonnage(meso_prescribed) %> vol</span>
          <% end %>
          <% if meso_actual > 0 %>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-600 font-['JetBrains_Mono',monospace]"><%= format_tonnage(meso_actual) %> logged</span>
          <% end %>
        </h3>

        <% mesocycle.microcycles.order(:week_number).each do |micro| %>
          <details class="border border-slate-200 rounded-md mb-1 bg-white">
            <summary class="px-4 py-2.5 cursor-pointer text-sm font-medium text-slate-700 hover:bg-slate-50">
              Week <%= micro.week_number %>
              <span class="text-slate-400 font-normal ml-2"><%= micro.training_sessions.count %> sessions</span>
              <% week_prescribed = micro.prescribed_tonnage %>
              <% week_actual = micro.actual_tonnage %>
              <% if week_prescribed > 0 %>
                <span class="text-slate-400 font-normal ml-2 font-['JetBrains_Mono',monospace] text-xs"><%= format_tonnage(week_prescribed) %> vol</span>
              <% end %>
              <% if week_actual > 0 %>
                <span class="text-emerald-500 font-normal ml-1 font-['JetBrains_Mono',monospace] text-xs"><%= format_tonnage(week_actual) %> logged</span>
              <% end %>
            </summary>

            <div class="px-4 pb-3">
              <% micro.training_sessions.order(:day).each do |session| %>
                <div class="mt-3">
                  <div class="flex items-center justify-between mb-1">
                    <div class="flex items-center gap-3">
                      <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">
                        <%= %w[Mon Tue Wed Thu Fri Sat Sun][session.day] || "Day #{session.day}" %> — <%= session.session_type.titleize %>
                      </span>
                      <% training_method = session.session_exercises.find_by("group_type IS NOT NULL")&.group_type %>
                      <% if training_method %>
                        <span class="text-[10px] px-1.5 py-0.5 rounded font-medium
                          <%= mesocycle.accumulation? ? 'bg-teal-100 text-teal-700' : 'bg-amber-100 text-amber-700' %>">
                          <%= training_method.titleize.gsub("Post Exhaustion", "Post-Exhaustion") %>
                        </span>
                      <% end %>
                      <span class="text-[10px] text-slate-400 font-['JetBrains_Mono',monospace]">~<%= session.estimated_duration %></span>
                      <% session_prescribed = session.prescribed_tonnage %>
                      <% session_actual = session.actual_tonnage %>
                      <% if session_prescribed > 0 %>
                        <span class="text-[10px] text-slate-400 font-['JetBrains_Mono',monospace]"><%= format_tonnage(session_prescribed) %> vol</span>
                      <% end %>
                    </div>
                    <div class="flex items-center gap-2">
                      <% if session.logged? %>
                        <span class="text-[10px] px-1.5 py-0.5 rounded font-medium bg-emerald-100 text-emerald-700">Logged<%= " #{session.completed_at.strftime('%-m/%-d')}" if session.completed_at %><%= " · #{format_tonnage(session_actual)}" if session_actual > 0 %></span>
                      <% end %>
                      <%= link_to "Log Workout", client_workout_path(@client, session), class: "text-xs text-teal-600 hover:text-teal-700 font-medium" %>
                    </div>
                  </div>

                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b border-slate-200">
                        <th class="text-left text-[10px] font-medium text-slate-400 uppercase px-2 py-1 w-10">Pos</th>
                        <th class="text-left text-[10px] font-medium text-slate-400 uppercase px-2 py-1">Exercise</th>
                        <th class="text-right text-[10px] font-medium text-slate-400 uppercase px-2 py-1 w-12">Sets</th>
                        <th class="text-right text-[10px] font-medium text-slate-400 uppercase px-2 py-1 w-12">Reps</th>
                        <th class="text-right text-[10px] font-medium text-slate-400 uppercase px-2 py-1 w-20">Tempo</th>
                        <th class="text-right text-[10px] font-medium text-slate-400 uppercase px-2 py-1 w-12">Rest</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% session.session_exercises.order(:position).each do |se| %>
                        <%= render "programs/session_exercise_row", se: se, client: @client, program: @program %>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# Shared exercise swap modal %>
<div id="swap-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40" onclick="if(event.target===this) this.classList.add('hidden')">
  <div class="bg-white rounded-lg shadow-lg border border-slate-200 p-6 w-full max-w-lg mx-4" onclick="event.stopPropagation()">
    <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-base mb-1">Swap Exercise</h3>
    <p class="text-sm text-slate-500 mb-4">Replace <strong id="swap-exercise-name"></strong> (<span id="swap-position"></span>) with:</p>

    <form id="swap-form" method="post" data-turbo="true">
      <input type="hidden" name="_method" value="patch">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div class="mb-4">
        <label class="block text-xs font-medium text-slate-400 mb-1">Search exercises</label>
        <input type="text" id="swap-search" placeholder="Type to filter..."
               class="w-full px-3 py-2 rounded-md border border-slate-300 text-sm mb-2 focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1"
               oninput="filterExercises(this, 'swap-select')">

        <select name="kilo_exercise_id" id="swap-select" size="8"
                class="w-full px-2 py-1 rounded border border-slate-300 text-sm font-['JetBrains_Mono',monospace]">
          <% KiloExercise.available_for(Current.user).order(:body_region, :category, :subcategory, :name).group_by { |e|
               label = e.body_region.to_s
               label += " — #{e.category}" if e.category.present?
               label += " — #{e.subcategory}" if e.subcategory.present?
               label
             }.each do |group_label, exercises| %>
            <optgroup label="<%= group_label %>">
              <% exercises.each do |ex| %>
                <option value="<%= ex.id %>"><%= ex.name %></option>
              <% end %>
            </optgroup>
          <% end %>
        </select>
      </div>

      <div class="mb-4 bg-slate-50 rounded-md p-3">
        <label class="block text-xs font-medium text-slate-500 mb-2">Apply change to:</label>
        <div class="flex gap-4">
          <label class="flex items-center gap-1.5 text-sm text-slate-600">
            <input type="radio" name="scope" value="exercise" checked class="text-teal-600"> This exercise only
          </label>
          <label class="flex items-center gap-1.5 text-sm text-slate-600">
            <input type="radio" name="scope" value="mesocycle" class="text-teal-600"> Entire mesocycle
          </label>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="px-4 py-2 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700">Save</button>
        <button type="button" onclick="document.getElementById('swap-modal').classList.add('hidden')" class="text-sm text-slate-500 hover:text-slate-700">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function openSwapModal(exerciseId, exerciseName, position, updateUrl) {
  document.getElementById('swap-exercise-name').textContent = exerciseName;
  document.getElementById('swap-position').textContent = position;
  document.getElementById('swap-form').action = updateUrl;
  document.getElementById('swap-search').value = '';
  var options = document.getElementById('swap-select').querySelectorAll('option');
  options.forEach(function(opt) { opt.style.display = ''; });
  var groups = document.getElementById('swap-select').querySelectorAll('optgroup');
  groups.forEach(function(g) { g.style.display = ''; });
  document.getElementById('swap-modal').classList.remove('hidden');
}

function patchExercise(url, data) {
  fetch(url, {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
      'Accept': 'application/json'
    },
    body: JSON.stringify(data)
  });
}

function saveTempo(input) {
  var id = input.dataset.exerciseId;
  var group = document.querySelector('[data-tempo-group="' + id + '"]');
  if (!group) return;
  var inputs = group.querySelectorAll('input[data-tempo-index]');
  var parts = [];
  inputs.forEach(function(inp) { parts.push(inp.value || '0'); });
  var tempo = parts.join('-');
  var url = group.dataset.exerciseUrl;
  if (url) patchExercise(url, {tempo: tempo});
}

function tempoNav(event, input) {
  var idx = parseInt(input.dataset.tempoIndex);
  var id = input.dataset.exerciseId;
  var group = document.querySelector('[data-tempo-group="' + id + '"]');
  var inputs = group.querySelectorAll('input[data-tempo-index]');
  var maxLen = parseInt(input.maxLength) || 2;

  if (event.key === 'ArrowRight' || (event.key === 'Tab' && !event.shiftKey)) {
    if (idx < inputs.length - 1) { event.preventDefault(); inputs[idx + 1].focus(); inputs[idx + 1].select(); }
  } else if (event.key === 'ArrowLeft' || (event.key === 'Tab' && event.shiftKey)) {
    if (idx > 0) { event.preventDefault(); inputs[idx - 1].focus(); inputs[idx - 1].select(); }
  } else if (event.key >= '0' && event.key <= '9' || event.key.toUpperCase() === 'X') {
    if (maxLen <= 1) {
      // Single-digit: replace and auto-advance (original behavior)
      input.value = event.key.toUpperCase();
      event.preventDefault();
      if (idx < inputs.length - 1) { inputs[idx + 1].focus(); inputs[idx + 1].select(); }
      else { saveTempo(input); }
    }
    // Multi-digit: let the browser handle input naturally (no preventDefault)
    // Auto-advance after input settles if at maxlength
  } else if (event.key === 'Enter') {
    event.preventDefault();
    saveTempo(input);
  }
}

// For multi-digit tempo inputs: auto-advance when maxlength is reached
document.addEventListener('input', function(e) {
  var input = e.target;
  if (!input.dataset || !input.dataset.tempoIndex) return;
  var maxLen = parseInt(input.maxLength) || 2;
  if (maxLen > 1 && input.value.length >= maxLen) {
    var idx = parseInt(input.dataset.tempoIndex);
    var id = input.dataset.exerciseId;
    var group = document.querySelector('[data-tempo-group="' + id + '"]');
    if (!group) return;
    var inputs = group.querySelectorAll('input[data-tempo-index]');
    if (idx < inputs.length - 1) { inputs[idx + 1].focus(); inputs[idx + 1].select(); }
    else { saveTempo(input); }
  }
});

function filterExercises(input, selectId) {
  var filter = input.value.toLowerCase();
  var select = document.getElementById(selectId);
  var options = select.querySelectorAll('option');
  options.forEach(function(opt) {
    opt.style.display = opt.textContent.toLowerCase().includes(filter) ? '' : 'none';
  });
  var groups = select.querySelectorAll('optgroup');
  groups.forEach(function(g) {
    var visible = g.querySelectorAll('option:not([style*="display: none"])').length;
    g.style.display = visible > 0 ? '' : 'none';
  });
}
</script>
