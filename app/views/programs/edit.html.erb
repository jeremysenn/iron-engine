<%= page_header "Edit Program" do %>
  <%= btn_secondary "Back", client_program_path(@client, @program) %>
<% end %>

<% sc = "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1" %>

<div class="max-w-lg">
  <%= form_with model: @program, url: client_program_path(@client, @program), class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Goal</label>
      <%= f.select :goal, Program.goals.keys.map { |k| [k.titleize, k] }, {}, class: sc %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Volume Tolerance</label>
      <%= f.select :volume, Program.volumes.keys.map { |k| [k.titleize, k] }, {}, class: sc %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Frequency</label>
      <%= f.select :frequency, (2..5).map { |n| ["#{n}x / week", n] }, {}, class: sc %>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Periodization Model</label>
      <div class="px-3 py-2.5 rounded-md border border-slate-200 bg-slate-50 text-sm font-['JetBrains_Mono',monospace] text-slate-600">
        <%= @program.periodization_model %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Status</label>
      <%= f.select :status, Program.statuses.keys.map { |k| [k.titleize, k] }, {}, class: sc %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Save Changes", class: "px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors" %>
      <%= link_to "Cancel", client_program_path(@client, @program), class: "text-sm text-slate-500 hover:text-slate-700" %>
    </div>
  <% end %>
</div>
