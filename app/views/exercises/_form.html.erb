<%= form_with model: exercise, class: "space-y-4" do |f| %>
  <% if exercise.errors.any? %>
    <div class="px-4 py-3 rounded-md border-l-3 border-red-600 bg-red-50 text-red-800 text-sm">
      <ul class="list-disc list-inside">
        <% exercise.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-500 mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1", autofocus: true, placeholder: "e.g. Press - Seated - DB - One-Arm" %>
  </div>

  <% sc = "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1" %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-slate-500 mb-1">Body Region</label>
      <%= f.select :body_region, options_for_select(["Upper Body", "Lower Body"], exercise.body_region), { prompt: "Select region" }, class: sc %>
    </div>
    <div>
      <%= f.label :category, class: "block text-sm font-medium text-slate-500 mb-1" %>
      <% ub_cats = ["Overhead Press","Incline Press","Flat Press","Decline Press","Push-Up","Chin-Up","Pull-Up","Row","Pulldown","Front Lever","Triceps","Biceps","Lateral Deltoid","Posterior Deltoid","Pectorals","Upper Back","External Rotators","Scapular Retractors","Shoulder Flexion","Neck","Forearms"] %>
      <% lb_cats = ["Squat","Deadlift","Knee Extension","Knee Flexion","Hip Extension","Calves","Abdominals"] %>
      <%= f.select :category, options_for_select((ub_cats + lb_cats).uniq, exercise.category), { prompt: "Select category" }, class: sc %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :subcategory, class: "block text-sm font-medium text-slate-500 mb-1" %>
      <%= f.text_field :subcategory, class: sc, placeholder: "e.g. Arm in Front, Long Range, Soleus" %>
    </div>
    <div>
      <%= f.label :equipment, class: "block text-sm font-medium text-slate-500 mb-1" %>
      <%= f.select :equipment, options_for_select(["barbell","dumbbell","cable","machine","bodyweight","band","other"].map { |e| [e.titleize, e] }, exercise.equipment), { prompt: "Select equipment" }, class: sc %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :grip_type, class: "block text-sm font-medium text-slate-500 mb-1" %>
      <%= f.text_field :grip_type, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1", placeholder: "e.g. semi_supinated" %>
    </div>
    <div>
      <%= f.label :grip_width, class: "block text-sm font-medium text-slate-500 mb-1" %>
      <%= f.text_field :grip_width, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1", placeholder: "e.g. medium" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors" %>
    <%= link_to "Cancel", exercises_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>
