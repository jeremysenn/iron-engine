<%= page_header @exercise.name do %>
  <div class="flex items-center gap-3">
    <% if @exercise.custom? %>
      <%= btn_secondary "Edit", edit_exercise_path(@exercise) %>
    <% end %>
    <%= btn_secondary "Back", exercises_path %>
  </div>
<% end %>

<div class="max-w-2xl space-y-4">
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <table class="w-full text-sm">
      <tbody>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500 w-32">Body Region</td>
          <td class="py-2 font-medium"><%= @exercise.body_region || "—" %></td>
        </tr>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Category</td>
          <td class="py-2 font-medium"><%= @exercise.category || "—" %></td>
        </tr>
        <% if @exercise.subcategory.present? %>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Subcategory</td>
          <td class="py-2 font-medium"><%= @exercise.subcategory %></td>
        </tr>
        <% end %>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Equipment</td>
          <td class="py-2 font-medium"><%= @exercise.equipment&.titleize || "—" %></td>
        </tr>
        <% if @exercise.grip_type.present? %>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Grip Type</td>
          <td class="py-2 font-medium"><%= @exercise.grip_type.titleize %></td>
        </tr>
        <% end %>
        <% if @exercise.grip_width.present? %>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Grip Width</td>
          <td class="py-2 font-medium"><%= @exercise.grip_width.titleize %></td>
        </tr>
        <% end %>
        <% if @exercise.rotation_group.present? %>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Rotation Group</td>
          <td class="py-2 font-medium"><%= @exercise.rotation_group.titleize %></td>
        </tr>
        <% end %>
        <% if @exercise.video_url.present? && @exercise.video_url.match?(%r{\Ahttps?://}i) %>
        <tr class="border-b border-slate-100">
          <td class="py-2 text-slate-500">Video</td>
          <td class="py-2">
            <%= link_to "Watch Demo", @exercise.video_url, target: "_blank", rel: "noopener", class: "text-teal-600 hover:text-teal-700 font-medium text-sm" %>
          </td>
        </tr>
        <% end %>
        <tr>
          <td class="py-2 text-slate-500">Source</td>
          <td class="py-2">
            <% if @exercise.custom? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-teal-100 text-teal-700">Custom</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-700">KILO Standard</span>
            <% end %>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <% if @exercise.video_url.present? %>
    <div class="bg-white rounded-lg border border-slate-200 p-4 mt-4">
      <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-sm text-slate-700 mb-3">Video Demonstration</h3>
      <% video_id = @exercise.video_url.to_s.split("/").last.split("?").first %>
      <div class="aspect-video rounded-md overflow-hidden bg-slate-900">
        <iframe src="https://www.youtube.com/embed/<%= video_id %>" class="w-full h-full" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen></iframe>
      </div>
    </div>
  <% end %>
</div>
