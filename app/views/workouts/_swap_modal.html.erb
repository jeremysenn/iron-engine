<%# Swap modal for one exercise. Rendered OUTSIDE the main logging form (its
    own <form> must not nest inside the main form). On the Log Workout page a
    submit handler (see workouts/show) intercepts this form and swaps just the
    one card in place, so unsaved weight/reps in the other cards survive. With
    JS off it submits normally and the controller redirects (today's behavior).
    Locals: se (SessionExercise), client (Client), available_exercises. %>
<div id="swap-form-<%= se.id %>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40" onclick="if(event.target===this) this.classList.add('hidden')">
  <div class="bg-white rounded-lg shadow-lg border border-slate-200 p-6 w-full max-w-lg mx-4" onclick="event.stopPropagation()">
    <h3 class="font-['Satoshi',system-ui,sans-serif] font-bold text-base mb-1">Swap Exercise</h3>
    <p class="text-sm text-slate-500 mb-4">Replace <strong><%= se.exercise_name %></strong> (<%= se.position %>) with:</p>

    <%= form_with url: client_session_exercise_path(client, se), method: :patch do %>
      <div class="mb-4">
        <label class="block text-xs font-medium text-slate-400 mb-1">Search exercises</label>
        <input type="text" id="search-<%= se.id %>" placeholder="Type to filter..."
               class="w-full px-3 py-2 rounded-md border border-slate-300 text-sm mb-2 focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1"
               oninput="filterExercises(this, 'select-<%= se.id %>')">

        <select name="kilo_exercise_id" id="select-<%= se.id %>" size="10"
                class="w-full px-2 py-1 rounded border border-slate-300 text-sm font-['JetBrains_Mono',monospace]">
          <%= render "exercises/swap_options", exercises: available_exercises, selected_id: se.kilo_exercise_id %>
        </select>
      </div>

      <p class="text-xs text-slate-400 mb-3">Or enter a custom exercise name:</p>
      <input type="text" name="exercise_name" placeholder="Custom exercise name (leave blank to use selection above)"
             class="w-full px-3 py-2 rounded-md border border-slate-300 text-sm mb-4 focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">

      <div class="mb-4 bg-slate-50 rounded-md p-3">
        <label class="block text-xs font-medium text-slate-500 mb-2">Apply change to:</label>
        <div class="flex gap-4">
          <label class="flex items-center gap-1.5 text-sm text-slate-600">
            <input type="radio" name="scope" value="workout" checked class="text-teal-600"> This workout only
          </label>
          <label class="flex items-center gap-1.5 text-sm text-slate-600">
            <input type="radio" name="scope" value="mesocycle" class="text-teal-600"> Entire mesocycle
          </label>
        </div>
        <p class="text-[10px] text-slate-400 mt-1">Mesocycle: updates all weeks in this phase with the same session type</p>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="px-4 py-2 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700">Save</button>
        <button type="button" onclick="this.closest('[id^=swap-form]').classList.add('hidden')" class="text-sm text-slate-500 hover:text-slate-700">Cancel</button>
      </div>
    <% end %>
  </div>
</div>
