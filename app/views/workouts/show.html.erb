<%= page_header @session.template_name do %>
  <%= btn_secondary "Back to Program", client_program_path(@client, @program) %>
<% end %>

<div class="font-['JetBrains_Mono',monospace] text-sm text-slate-500 mb-4">
  <%= @client.full_name %> · Week <%= @session.microcycle.week_number %> ·
  <%= %w[Monday Tuesday Wednesday Thursday Friday Saturday Sunday][@session.day] || "Day #{@session.day}" %>
  · ~<%= @session.estimated_duration %>
</div>

<% workout_prescribed = @session.prescribed_tonnage %>
<% workout_actual = @session.actual_tonnage %>
<% if workout_prescribed > 0 || workout_actual > 0 %>
  <div class="flex items-center gap-4 mb-6 px-4 py-2.5 rounded-md border border-slate-200 bg-white font-['JetBrains_Mono',monospace] text-sm">
    <% if workout_prescribed > 0 %>
      <div>
        <span class="text-[10px] text-slate-400 uppercase tracking-wider">Prescribed</span>
        <p class="font-semibold text-slate-700"><%= format_tonnage(workout_prescribed) %></p>
      </div>
    <% end %>
    <% if workout_actual > 0 %>
      <div class="border-l border-slate-200 pl-4">
        <span class="text-[10px] text-emerald-500 uppercase tracking-wider">Actual</span>
        <p class="font-semibold text-emerald-700"><%= format_tonnage(workout_actual) %></p>
      </div>
    <% end %>
  </div>
<% end %>

<%# Swap exercise modals (outside the main form so their <form> doesn't nest).
    The submit listener below intercepts these forms and fetches with an
    X-Inline-Swap header; the controller returns just the re-rendered card,
    which the JS swaps in via outerHTML, preserving unsaved entries elsewhere. %>
<% @exercises.each do |se| %>
  <%= render "swap_modal", se: se, client: @client, available_exercises: @available_exercises %>
<% end %>

<%# Main workout logging form %>
<%= form_with url: client_workout_path(@client, @session), method: :patch, class: "space-y-6" do |f| %>
  <div class="flex items-center gap-3">
    <label class="text-sm font-medium text-slate-600">Date</label>
    <input type="date" name="completed_at" value="<%= @session.completed_at || Date.current %>"
           class="px-3 py-1.5 rounded-md border border-slate-300 text-sm font-['JetBrains_Mono',monospace] focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
  </div>

  <% @exercises.each do |se| %>
    <%= render "exercise_card", se: se, program: @program %>
  <% end %>

  <div class="flex items-center gap-3 pt-2">
    <input type="submit" value="Save Workout" class="px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors">
    <%= link_to "Cancel", client_program_path(@client, @program), class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>

<script>
// Swap an exercise without losing unsaved weight/reps in the other cards.
// Intercepts the swap modal's form, posts it in the background, and replaces
// just that one card. Falls back to a normal submit (redirect) if the request
// fails, so the worst case matches the pre-existing behavior.
document.addEventListener("submit", function (e) {
  var form = e.target;
  var modal = form.closest && form.closest('[id^="swap-form-"]');
  if (!modal) return; // not a swap form — leave the main logging form alone

  e.preventDefault();
  var seId = modal.id.replace("swap-form-", "");

  fetch(form.action, {
    method: "POST", // form carries _method=patch
    body: new FormData(form),
    headers: { "X-Inline-Swap": "1", "Accept": "text/html" }
  })
    .then(function (r) {
      // A redirect means the controller did NOT render a card (e.g. an error
      // path). Follow it as a real navigation rather than injecting a whole
      // page into one card.
      if (r.redirected) { window.location.href = r.url; return null; }
      return r.ok ? r.text() : Promise.reject(r.status);
    })
    .then(function (html) {
      if (html === null) return; // already navigating
      var card = document.getElementById("exercise-card-" + seId);
      if (card) card.outerHTML = html;
      modal.classList.add("hidden");
    })
    .catch(function () { form.submit(); }); // fallback: full-page submit
});

function filterExercises(input, selectId) {
  const filter = input.value.toLowerCase();
  const select = document.getElementById(selectId);
  const groups = select.querySelectorAll('optgroup');

  groups.forEach(group => {
    let visibleCount = 0;
    group.querySelectorAll('option').forEach(opt => {
      const match = opt.textContent.toLowerCase().includes(filter) ||
                    group.label.toLowerCase().includes(filter);
      opt.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });
    group.style.display = visibleCount > 0 ? '' : 'none';
  });
}
</script>
