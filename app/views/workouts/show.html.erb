<%= page_header @session.template_name do %>
  <%= btn_secondary "Back to Program", client_program_path(@client, @program) %>
<% end %>

<div class="font-['JetBrains_Mono',monospace] text-sm text-slate-500 mb-6">
  <%= @client.full_name %> · Week <%= @session.microcycle.week_number %> ·
  <%= %w[Monday Tuesday Wednesday Thursday Friday Saturday Sunday][@session.day] || "Day #{@session.day}" %>
</div>

<%= form_with url: client_workout_path(@client, @session), method: :patch, class: "space-y-6" do |f| %>
  <% @exercises.each do |se| %>
    <div class="exercise-card bg-white rounded-lg border border-slate-200 overflow-hidden">
      <div class="px-4 py-3 bg-slate-50 border-b border-slate-200">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="font-['JetBrains_Mono',monospace] text-xs text-slate-400 w-6"><%= se.position %></span>
            <% if se.kilo_exercise_id %>
              <%= link_to se.exercise_name, exercise_path(se.kilo_exercise_id), class: "font-medium text-sm text-slate-700 hover:text-teal-600" %>
            <% else %>
              <span class="font-medium text-sm text-slate-700"><%= se.exercise_name %></span>
            <% end %>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-slate-400 font-['JetBrains_Mono',monospace]"><%= se.tempo %> · <%= se.rest_seconds %>s</span>
            <button onclick="this.closest('.exercise-card').querySelector('.swap-panel').classList.toggle('hidden')"
                    class="text-xs text-teal-600 hover:text-teal-700 font-medium">Swap</button>
          </div>
        </div>
        <%# Exercise swap panel (hidden by default) %>
        <div class="swap-panel hidden mt-3 pt-3 border-t border-slate-200">
          <%= form_with url: client_session_exercise_path(@client, se), method: :patch, class: "flex items-end gap-2" do %>
            <div class="flex-1">
              <label class="block text-xs text-slate-400 mb-1">Replace with</label>
              <select name="kilo_exercise_id" class="w-full px-2 py-1.5 rounded border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1">
                <option value="">— Select exercise —</option>
                <% KiloExercise.available_for(Current.user).order(:category, :name).group_by(&:category).each do |cat, exercises| %>
                  <optgroup label="<%= cat.titleize %>">
                    <% exercises.each do |ex| %>
                      <option value="<%= ex.id %>" <%= 'selected' if ex.id == se.kilo_exercise_id %>><%= ex.name %></option>
                    <% end %>
                  </optgroup>
                <% end %>
              </select>
            </div>
            <button type="submit" class="px-3 py-1.5 rounded text-xs font-medium text-white bg-teal-600 hover:bg-teal-700">Save</button>
          <% end %>
        </div>
      </div>

      <table class="w-full">
        <thead>
          <tr class="border-b border-slate-100">
            <th class="text-center text-[10px] font-medium text-slate-400 uppercase px-3 py-1.5 w-16">Set</th>
            <th class="text-center text-[10px] font-medium text-slate-400 uppercase px-3 py-1.5">Target</th>
            <th class="text-center text-[10px] font-medium text-slate-400 uppercase px-3 py-1.5">Weight (lbs)</th>
            <th class="text-center text-[10px] font-medium text-slate-400 uppercase px-3 py-1.5">Reps</th>
          </tr>
        </thead>
        <tbody>
          <% se.exercise_sets.order(:set_number).each do |set| %>
            <tr class="border-b border-slate-50">
              <td class="text-center py-2 font-['JetBrains_Mono',monospace] text-sm text-slate-400">
                <%= set.set_number %>
              </td>
              <td class="text-center py-2 font-['JetBrains_Mono',monospace] text-xs text-slate-400">
                <%= set.target_reps %> reps
              </td>
              <td class="text-center py-2 px-2">
                <input type="number" step="0.5" min="0"
                       name="sets[<%= set.id %>][actual_weight]"
                       value="<%= set.actual_weight if set.actual_weight.to_f > 0 %>"
                       placeholder="—"
                       class="w-24 mx-auto block text-center px-2 py-1.5 rounded border border-slate-200 text-sm font-['JetBrains_Mono',monospace] focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 <%= set.actual_weight.to_f > 0 ? 'bg-teal-50 border-teal-200' : '' %>">
              </td>
              <td class="text-center py-2 px-2">
                <input type="number" min="0"
                       name="sets[<%= set.id %>][actual_reps]"
                       value="<%= set.actual_reps if set.actual_reps.to_i > 0 %>"
                       placeholder="—"
                       class="w-20 mx-auto block text-center px-2 py-1.5 rounded border border-slate-200 text-sm font-['JetBrains_Mono',monospace] focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 <%= set.actual_reps.to_i > 0 ? 'bg-teal-50 border-teal-200' : '' %>">
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="flex items-center gap-3 pt-2">
    <input type="submit" value="Save Workout" class="px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors">
    <%= link_to "Cancel", client_program_path(@client, @program), class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>
