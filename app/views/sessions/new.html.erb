<div class="w-full max-w-sm">
  <div class="text-center mb-8">
    <h1 class="font-['Satoshi',system-ui,sans-serif] font-black text-3xl text-white mb-2">
      Iron<span class="text-teal-500">Engine</span>
    </h1>
    <!--
      <p class="text-slate-400 text-sm">KILO-powered program design for strength coaches</p>
    -->
  </div>

  <div class="bg-slate-800 rounded-lg border border-slate-700 p-6">
    <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg text-white mb-5">Sign in</h2>

    <% if alert = flash[:alert] %>
      <div class="mb-4 px-3 py-2 rounded-md border-l-3 border-red-500 bg-red-900/30 text-red-300 text-sm"><%= alert %></div>
    <% end %>

    <% if notice = flash[:notice] %>
      <div class="mb-4 px-3 py-2 rounded-md border-l-3 border-emerald-500 bg-emerald-900/30 text-emerald-300 text-sm"><%= notice %></div>
    <% end %>

    <%= form_with url: session_url, class: "space-y-4" do |form| %>
      <div>
        <label for="email_address" class="block text-sm font-medium text-slate-400 mb-1">Email</label>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
            value: params[:email_address],
            class: "w-full px-3 py-2.5 rounded-md bg-slate-900 border border-slate-600 text-white text-sm placeholder-slate-500 focus:outline-2 focus:outline-teal-500 focus:-outline-offset-1 focus:border-teal-500" %>
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-slate-400 mb-1">Password</label>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72,
            class: "w-full px-3 py-2.5 rounded-md bg-slate-900 border border-slate-600 text-white text-sm placeholder-slate-500 focus:outline-2 focus:outline-teal-500 focus:-outline-offset-1 focus:border-teal-500" %>
      </div>

      <div class="pt-1">
        <%= form.submit "Sign in", class: "w-full px-4 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors" %>
      </div>
    <% end %>

    <div class="mt-4 flex items-center justify-between text-sm">
      <%= link_to "Forgot password?", new_password_path, class: "text-slate-500 hover:text-slate-300 transition-colors" %>
    </div>
  </div>

  <p class="text-center mt-6 text-sm text-slate-500">
    Don't have an account?
    <%= link_to "Sign up", new_registration_path, class: "text-teal-500 hover:text-teal-400 font-medium" %>
  </p>
</div>
