<%= form_with model: client, class: "space-y-4" do |f| %>
  <% if client.errors.any? %>
    <div class="px-4 py-3 rounded-md border-l-3 border-red-600 bg-red-50 text-red-800 text-sm">
      <ul class="list-disc list-inside">
        <% client.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :first_name, class: "block text-sm font-medium text-slate-500 mb-1" %>
    <%= f.text_field :first_name, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 focus:border-teal-600", autofocus: true %>
  </div>

  <div>
    <%= f.label :last_name, class: "block text-sm font-medium text-slate-500 mb-1" %>
    <%= f.text_field :last_name, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 focus:border-teal-600" %>
  </div>

  <div>
    <%= f.label :training_age, class: "block text-sm font-medium text-slate-500 mb-1" %>
    <%= f.select :training_age, Client.training_ages.keys.map { |k| [k.capitalize, k] }, { prompt: "Select training age" }, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 focus:border-teal-600" %>
  </div>

  <div>
    <%= f.label :date_of_birth, class: "block text-sm font-medium text-slate-500 mb-1" %>
    <%= f.date_field :date_of_birth, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm font-['JetBrains_Mono',monospace] focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 focus:border-teal-600" %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-slate-500 mb-1" %>
    <%= f.text_area :notes, rows: 3, class: "w-full px-3 py-2.5 rounded-md border border-slate-300 text-sm focus:outline-2 focus:outline-teal-600 focus:-outline-offset-1 focus:border-teal-600" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "px-5 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 cursor-pointer transition-colors" %>
    <%= link_to "Cancel", (client.persisted? ? client_path(client) : clients_path), class: "text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>
