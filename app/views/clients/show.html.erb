<%= page_header @client.full_name do %>
  <div class="flex items-center gap-3">
    <%= btn_primary "Generate Program", new_client_program_path(@client) %>
    <%= btn_secondary "Edit", edit_client_path(@client) %>
  </div>
<% end %>

<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <div class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-1">Training Age</div>
    <div class="text-lg font-['Satoshi',system-ui,sans-serif] font-bold"><%= @client.training_age.capitalize %></div>
  </div>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <div class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-1">Assessments</div>
    <div class="text-lg font-['JetBrains_Mono',monospace] font-semibold"><%= @assessments.count %></div>
  </div>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <div class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-1">Active Program</div>
    <div class="text-lg font-['JetBrains_Mono',monospace] font-semibold">
      <%= @active_program ? "#{@active_program.goal.titleize}" : "None" %>
    </div>
  </div>
</div>

<% if @active_program %>
  <div class="mb-8">
    <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg mb-3">Active Program</h2>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <div class="flex items-center justify-between mb-3">
        <div class="font-['JetBrains_Mono',monospace] text-sm text-slate-500">
          <%= @active_program.goal.titleize %> · <%= @active_program.training_level.capitalize %> · <%= @active_program.volume.capitalize %> Volume · Model <%= @active_program.periodization_model %> · <%= @active_program.split_type&.titleize || "Upper / Lower" %> · <%= @active_program.frequency %>x/week<% if @active_program.map_applied? %> · <span class="text-teal-600">MAP Applied</span><% end %>
        </div>
        <%= link_to "View Program", client_program_path(@client, @active_program), class: "text-sm text-teal-600 hover:text-teal-700 font-medium" %>
      </div>
      <% active_prescribed = @active_program.prescribed_tonnage %>
      <% active_actual = @active_program.actual_tonnage %>
      <% if active_prescribed > 0 || active_actual > 0 %>
        <div class="flex items-center gap-4 mt-2 pt-2 border-t border-slate-100 font-['JetBrains_Mono',monospace] text-sm">
          <% if active_prescribed > 0 %>
            <div>
              <span class="text-[10px] text-slate-400 uppercase tracking-wider">Prescribed Tonnage</span>
              <p class="font-semibold text-slate-700"><%= format_tonnage(active_prescribed) %></p>
            </div>
          <% end %>
          <% if active_actual > 0 %>
            <div class="<%= 'border-l border-slate-200 pl-4' if active_prescribed > 0 %>">
              <span class="text-[10px] text-emerald-500 uppercase tracking-wider">Actual Tonnage</span>
              <p class="font-semibold text-emerald-700"><%= format_tonnage(active_actual) %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @tonnage_data.any? %>
  <div class="mb-8">
    <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg mb-3">Total Tonnage Over Time</h2>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <canvas id="tonnage-chart" height="240"></canvas>
    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var rawData = <%= raw @tonnage_data.map { |date, tonnage| { date: date.to_s, tonnage: tonnage.to_f.round } }.to_json %>;
    var labels = rawData.map(function(d) { return d.date; });
    var values = rawData.map(function(d) { return d.tonnage; });

    new Chart(document.getElementById('tonnage-chart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Actual Tonnage',
          data: values,
          borderColor: '#0d9488',
          backgroundColor: 'rgba(13, 148, 136, 0.08)',
          fill: true,
          tension: 0.3,
          pointRadius: 4,
          pointBackgroundColor: '#0d9488',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointHoverRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                return ctx.parsed.y.toLocaleString() + ' total tonnage';
              }
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              font: { family: "'JetBrains Mono', monospace", size: 10 },
              color: '#94a3b8'
            }
          },
          y: {
            beginAtZero: true,
            ticks: {
              font: { family: "'JetBrains Mono', monospace", size: 10 },
              color: '#94a3b8',
              callback: function(value) { return value.toLocaleString(); }
            },
            grid: { color: 'rgba(148, 163, 184, 0.15)' }
          }
        }
      }
    });
  });
  </script>
<% end %>

<% if @archived_programs.any? %>
  <div class="mb-8">
    <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg mb-3">Program History</h2>
    <table class="w-full">
      <thead>
        <tr class="border-b-2 border-slate-200">
          <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Goal</th>
          <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Details</th>
          <th class="text-right text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Tonnage</th>
          <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Archived</th>
          <th class="text-right text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2"></th>
        </tr>
      </thead>
      <tbody>
        <% @archived_programs.each do |program| %>
          <tr class="border-b border-slate-200 hover:bg-slate-100/50">
            <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm"><%= program.goal.titleize %></td>
            <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm text-slate-500">
              <%= program.training_level.capitalize %> · <%= program.volume.capitalize %> · <%= program.frequency %>x/week · Macrocycle <%= program.macrocycle_number %><% if program.map_applied? %> · <span class="text-teal-600">MAP</span><% end %>
            </td>
            <td class="px-4 py-3 text-right font-['JetBrains_Mono',monospace] text-sm">
              <% arch_actual = program.actual_tonnage %>
              <% arch_prescribed = program.prescribed_tonnage %>
              <% if arch_actual > 0 %>
                <span class="text-slate-700"><%= format_tonnage(arch_actual) %></span>
              <% elsif arch_prescribed > 0 %>
                <span class="text-slate-500"><%= format_tonnage(arch_prescribed) %></span>
              <% else %>
                <span class="text-slate-300">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm text-slate-500"><%= program.archived_at&.strftime("%Y-%m-%d") %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to "View", client_program_path(@client, program), class: "text-sm text-teal-600 hover:text-teal-700" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# Share Link %>
<div class="mb-8">
  <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg mb-3">Client Share Link</h2>
  <div class="bg-white rounded-lg border border-slate-200 p-4">
    <% share_token = @client.active_share_token %>
    <% if share_token %>
      <p class="text-sm text-slate-500 mb-3">Share this link with <%= @client.first_name %> so they can view their program and log workouts.</p>
      <div class="flex items-center gap-2 mb-3">
        <input type="text" readonly value="<%= shared_url(share_token.token) %>" id="share-link"
               class="flex-1 px-3 py-2 rounded-md border border-slate-300 text-sm font-['JetBrains_Mono',monospace] bg-slate-50 text-slate-600">
        <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('share-link').value);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',2000)"
                class="px-4 py-2 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 transition-colors">Copy</button>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-xs text-slate-400 font-['JetBrains_Mono',monospace]">Expires <%= share_token.expires_at.strftime("%b %-d, %Y") %></span>
        <div class="flex items-center gap-3">
          <%= button_to "Regenerate", client_share_token_path(@client), method: :post, class: "text-xs text-teal-600 hover:text-teal-700 font-medium" %>
          <%= button_to "Revoke", client_share_token_path(@client), method: :delete, class: "text-xs text-red-600 hover:text-red-700 font-medium" %>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-slate-500 mb-3">Generate a link to share <%= @client.first_name %>'s program. They can view workouts and log their training — no account needed.</p>
      <%= button_to "Generate Share Link", client_share_token_path(@client), method: :post, class: "inline-flex items-center px-4 py-2.5 rounded-md text-sm font-medium text-white bg-teal-600 hover:bg-teal-700 transition-colors" %>
    <% end %>
  </div>
</div>

<div class="flex items-center justify-between mb-3">
  <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg">MAP Assessments</h2>
  <%= link_to "New MAP", new_client_map_assessment_path(@client), class: "text-sm text-teal-600 hover:text-teal-700 font-medium" %>
</div>

<% if @map_assessments.any? %>
  <table class="w-full mb-8">
    <thead>
      <tr class="border-b-2 border-slate-200">
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Date</th>
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Patterns</th>
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Status</th>
        <th class="text-right text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @map_assessments.each do |ma| %>
        <tr class="border-b border-slate-200 hover:bg-slate-100/50">
          <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm"><%= ma.assessed_at.strftime("%Y-%m-%d") %></td>
          <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm"><%= ma.map_progressions.count %>/15</td>
          <td class="px-4 py-3 text-sm">
            <% if ma.complete? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-700">Complete</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">Incomplete</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "View", client_map_assessment_path(@client, ma), class: "text-sm text-teal-600 hover:text-teal-700" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="text-center py-8 bg-white rounded-lg border border-slate-200 mb-8">
    <p class="text-slate-500 mb-2">No MAP assessments yet.</p>
    <p class="text-slate-400 text-sm mb-4">Run a MAP assessment to personalize exercise selection based on movement quality.</p>
    <%= btn_primary "Start MAP Assessment", new_client_map_assessment_path(@client) %>
  </div>
<% end %>

<div class="flex items-center justify-between mb-3">
  <h2 class="font-['Satoshi',system-ui,sans-serif] font-bold text-lg">PrimeEight Assessments</h2>
  <%= link_to "New PrimeEight", new_client_prime_eight_assessment_path(@client), class: "text-sm text-teal-600 hover:text-teal-700 font-medium" %>
</div>

<% if @assessments.any? %>
  <table class="w-full">
    <thead>
      <tr class="border-b-2 border-slate-200">
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Date</th>
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Lifts Recorded</th>
        <th class="text-right text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @assessments.each do |assessment| %>
        <tr class="border-b border-slate-200 hover:bg-slate-100/50">
          <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm"><%= assessment.assessed_at.strftime("%Y-%m-%d") %></td>
          <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm"><%= assessment.prime_eight_lifts.count %>/8</td>
          <td class="px-4 py-3 text-right">
            <%= link_to "View Ratios", client_prime_eight_assessment_path(@client, assessment), class: "text-sm text-teal-600 hover:text-teal-700" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="text-center py-12 bg-white rounded-lg border border-slate-200">
    <p class="text-slate-500 mb-2">No assessments yet.</p>
    <p class="text-slate-400 text-sm mb-4">Run a PrimeEight assessment to identify limiting lifts and generate a program.</p>
    <%= btn_primary "Start Assessment", new_client_prime_eight_assessment_path(@client) %>
  </div>
<% end %>
