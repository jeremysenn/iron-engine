<%= page_header "Clients" do %>
  <%= btn_primary "Add Client", new_client_path %>
<% end %>

<% if @clients.any? %>
  <table class="w-full">
    <thead>
      <tr class="border-b-2 border-slate-200">
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Name</th>
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Training Age</th>
        <th class="text-left text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2">Active Program</th>
        <th class="text-right text-xs font-medium text-slate-400 uppercase tracking-wider px-4 py-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr class="border-b border-slate-200 hover:bg-slate-100/50 transition-colors">
          <td class="px-4 py-3">
            <%= link_to client.full_name, client, class: "font-medium text-slate-900 hover:text-teal-600" %>
          </td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= case client.training_age
                  when 'novice' then 'bg-blue-100 text-blue-700'
                  when 'intermediate' then 'bg-amber-100 text-amber-700'
                  when 'advanced' then 'bg-red-100 text-red-700'
                  end %>">
              <%= client.training_age.capitalize %>
            </span>
          </td>
          <td class="px-4 py-3 font-['JetBrains_Mono',monospace] text-sm text-slate-500">
            <%= client.active_program ? "#{client.active_program.goal.titleize} · Model #{client.active_program.periodization_model}" : "—" %>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "View", client, class: "text-sm text-teal-600 hover:text-teal-700" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="text-center py-16">
    <p class="text-slate-500 mb-2">Welcome to IronEngine.</p>
    <p class="text-slate-400 text-sm mb-6">Add your first client to start building KILO-compliant programs.</p>
    <%= btn_primary "Add Your First Client", new_client_path %>
  </div>
<% end %>
