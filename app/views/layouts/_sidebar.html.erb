<%# Mobile top bar %>
<div class="lg:hidden bg-slate-900 flex items-center justify-between px-4 py-3">
  <span class="font-['Satoshi',system-ui,sans-serif] font-black text-lg text-white">Iron<span class="text-teal-600">Engine</span></span>
  <button onclick="document.getElementById('mobile-nav').classList.toggle('hidden')" class="text-slate-400 hover:text-white">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>
</div>
<div id="mobile-nav" class="hidden lg:hidden bg-slate-900 px-4 pb-4 space-y-1">
  <%= sidebar_link "Dashboard", root_path, active: current_page?(root_path) %>
  <%= sidebar_link "Clients", clients_path, active: controller_name == "clients" || controller_name.include?("assessment") || controller_name == "programs" %>
  <div class="pt-3 border-t border-slate-800 mt-3">
    <div class="text-xs text-slate-500 mb-1"><%= Current.user&.email_address %></div>
    <%= button_to "Sign out", session_path, method: :delete, class: "text-xs text-slate-500 hover:text-slate-300" %>
  </div>
</div>

<%# Desktop sidebar %>
<nav class="hidden lg:flex w-60 bg-slate-900 text-slate-300 flex-col shrink-0 min-h-screen">
  <div class="p-6 pb-8">
    <span class="font-['Satoshi',system-ui,sans-serif] font-black text-xl text-white">Iron<span class="text-teal-600">Engine</span></span>
  </div>

  <div class="flex-1 px-3 space-y-0.5">
    <%= sidebar_link "Dashboard", root_path, active: current_page?(root_path) %>
    <%= sidebar_link "Clients", clients_path, active: controller_name == "clients" || controller_name.include?("assessment") || controller_name == "programs" %>
  </div>

  <div class="p-4 border-t border-slate-800">
    <div class="text-xs text-slate-500 mb-2"><%= Current.user&.email_address %></div>
    <%= button_to "Sign out", session_path, method: :delete, class: "text-xs text-slate-500 hover:text-slate-300 transition-colors" %>
  </div>
</nav>
