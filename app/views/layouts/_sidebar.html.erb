<%# Mobile: top bar with hamburger %>
<div class="block lg:hidden bg-slate-900 px-4 py-3 flex items-center justify-between">
  <span class="flex items-center gap-2">
    <img src="/icon.svg" alt="IronEngine" class="w-7 h-7">
    <span class="font-['Satoshi',system-ui,sans-serif] font-black text-lg text-white">Iron<span class="text-teal-600">Engine</span></span>
  </span>
  <button id="menu-toggle" class="text-slate-400 hover:text-white" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>
</div>
<div id="mobile-menu" class="hidden lg:hidden bg-slate-900 px-4 pb-4 space-y-1">
  <%= sidebar_link "Dashboard", root_path, active: current_page?(root_path) %>
  <%= sidebar_link "Clients", clients_path, active: controller_name == "clients" || controller_name.include?("assessment") || controller_name == "programs" || controller_name == "workouts" %>
  <%= sidebar_link "Exercises", exercises_path, active: controller_name == "exercises" %>
  <div class="pt-3 border-t border-slate-800 mt-3">
    <div class="text-xs text-slate-500 mb-1"><%= Current.user&.email_address %></div>
    <%= button_to "Sign out", session_path, method: :delete, class: "text-xs text-slate-500 hover:text-slate-300" %>
  </div>
</div>

<%# Desktop: persistent sidebar %>
<nav class="hidden lg:block w-60 bg-slate-900 text-slate-300 shrink-0 min-h-screen">
  <div class="p-6 pb-8">
    <span class="font-['Satoshi',system-ui,sans-serif] font-black text-xl text-white">Iron<span class="text-teal-600">Engine</span></span>
  </div>

  <div class="flex-1 px-3 space-y-0.5">
    <%= sidebar_link "Dashboard", root_path, active: current_page?(root_path) %>
    <%= sidebar_link "Clients", clients_path, active: controller_name == "clients" || controller_name.include?("assessment") || controller_name == "programs" || controller_name == "workouts" %>
  <%= sidebar_link "Exercises", exercises_path, active: controller_name == "exercises" %>
  </div>

  <div class="absolute bottom-0 w-60 p-4 border-t border-slate-800">
    <div class="text-xs text-slate-500 mb-2"><%= Current.user&.email_address %></div>
    <%= button_to "Sign out", session_path, method: :delete, class: "text-xs text-slate-500 hover:text-slate-300 transition-colors" %>
  </div>
</nav>
